export const runtime = "nodejs";

import { NextResponse } from "next/server";
import { z } from "zod";
import { getServerSession } from "next-auth/next";

// ★ここをあなたのリポジトリに合わせて修正（2)で見つけた authOptions の場所）
// 例: import { authOptions } from "@/app/api/auth/[...nextauth]/route";
import { authOptions } from "@/lib/auth";

import { getSql } from "@/lib/db/neon";

const Uuid = z.string().uuid();

const BodySchema = z
  .object({
    // 互換: type / stampType / stamp_type
    type: z.string().optional(),
    stampType: z.string().optional(),
    stamp_type: z.string().optional(),

    // 必須: machine_id
    machineId: Uuid.optional(),
    machine_id: Uuid.optional(),

    // 任意: decided_site_id（UIが siteId を送る場合の互換）
    decidedSiteId: Uuid.optional(),
    decided_site_id: Uuid.optional(),
    siteId: Uuid.optional(),
    site_id: Uuid.optional(),

    // 任意: work_type_id
    workTypeId: Uuid.optional(),
    work_type_id: Uuid.optional(),

    // 必須（DBはNOT NULL）だが、未指定ならサーバで補完する
    workDescription: z.string().optional(),
    work_description: z.string().optional(),

    // 位置情報（DB列: lat / lon / accuracy_m）
    lat: z.coerce.number().optional(),
    lon: z.coerce.number().optional(),
    lng: z.coerce.number().optional(),
    longitude: z.coerce.number().optional(),
    accuracy: z.coerce.number().optional(),
    accuracy_m: z.coerce.number().optional(),

    // 位置情報のメタ
    positionTimestampMs: z.coerce.number().optional(),
    position_timestamp_ms: z.coerce.number().optional(),
    isCachedPosition: z.boolean().optional(),
    is_cached_position: z.boolean().optional(),

    // 判定メタ（DB: decision_method not null defaultあり）
    decisionMethod: z.string().optional(),
    decision_method: z.string().optional(),
    nearestDistanceM: z.coerce.number().optional(),
    nearest_distance_m: z.coerce.number().optional(),
    withinRadius: z.boolean().optional(),
    within_radius: z.boolean().optional(),

    // DB: auto_generated not null default false
    autoGenerated: z.boolean().optional(),
    auto_generated: z.boolean().optional(),

    // stamped_at（任意、未指定なら now）
    stampedAt: z.string().datetime().optional(),
  })
  .superRefine((d, ctx) => {
    const machineId = d.machineId ?? d.machine_id;
    if (!machineId) {
      ctx.addIssue({ code: "custom", message: "machineId is required", path: ["machineId"] });
    }

    const st = (d.stampType ?? d.stamp_type ?? d.type ?? "").toUpperCase();
    if (st !== "IN" && st !== "OUT") {
      ctx.addIssue({ code: "custom", message: "type/stampType must be IN or OUT", path: ["type"] });
    }
  })
  .transform((d) => {
    const stampType = (d.stampType ?? d.stamp_type ?? d.type ?? "").toUpperCase() as "IN" | "OUT";

    const machineId = d.machineId ?? d.machine_id ?? null;

    const decidedSiteId =
      d.decidedSiteId ?? d.decided_site_id ?? d.siteId ?? d.site_id ?? null;

    const workTypeId = d.workTypeId ?? d.work_type_id ?? null;

    const workDescriptionRaw = d.workDescription ?? d.work_description ?? "";
    const workDescription = workDescriptionRaw.trim().length > 0 ? workDescriptionRaw.trim() : "NFC打刻";

    const lat = d.lat ?? null;
    const lon = d.lon ?? d.lng ?? d.longitude ?? null;

    const accuracyM = d.accuracy_m ?? d.accuracy ?? null;

    const positionTimestampMs = d.position_timestamp_ms ?? d.positionTimestampMs ?? null;

    const isCachedPosition = d.is_cached_position ?? d.isCachedPosition ?? false;

    const decisionMethod = (d.decision_method ?? d.decisionMethod ?? "gps_nearest").trim() || "gps_nearest";

    const nearestDistanceM = d.nearest_distance_m ?? d.nearestDistanceM ?? null;
    const withinRadius = d.within_radius ?? d.withinRadius ?? null;

    const autoGenerated = d.auto_generated ?? d.autoGenerated ?? false;

    return {
      stampType,
      machineId,
      decidedSiteId,
      workTypeId,
      workDescription,
      lat,
      lon,
      accuracyM,
      positionTimestampMs,
      isCachedPosition,
      decisionMethod,
      nearestDistanceM,
      withinRadius,
      autoGenerated,
      stampedAt: d.stampedAt ?? null,
    };
  });

function toJstWorkDate(d: Date): string {
  // JST(UTC+9) の YYYY-MM-DD
  const jst = new Date(d.getTime() + 9 * 60 * 60 * 1000);
  return jst.toISOString().slice(0, 10);
}

export async function POST(req: Request) {
  const requestId =
    globalThis.crypto?.randomUUID?.() ?? Math.random().toString(16).slice(2);

  try {
    const session = await getServerSession(authOptions);

    // logs.user_id は uuid のため、uuidであることを要求
    const userId = (session as any)?.user?.id;
    if (!userId || !Uuid.safeParse(userId).success) {
      return NextResponse.json(
        { ok: false, error: "Unauthorized", requestId },
        { status: 401 }
      );
    }

    const json = await req.json().catch(() => null);
    const parsed = BodySchema.safeParse(json);

    if (!parsed.success) {
      return NextResponse.json(
        { ok: false, error: "Invalid request", issues: parsed.error.flatten(), requestId },
        { status: 400 }
      );
    }

    const input = parsed.data;

    const stampedAt = input.stampedAt ? new Date(input.stampedAt) : new Date();
    const workDate = toJstWorkDate(stampedAt);

    const sql = getSql();

    const rows = await sql`
      INSERT INTO logs (
        stamped_at,
        work_date,
        user_id,
        machine_id,
        decided_site_id,
        work_type_id,
        work_description,
        stamp_type,
        lat,
        lon,
        accuracy_m,
        position_timestamp_ms,
        is_cached_position,
        decision_method,
        nearest_distance_m,
        within_radius,
        auto_generated
      ) VALUES (
        ${stampedAt.toISOString()},
        ${workDate},
        ${userId},
        ${input.machineId},
        ${input.decidedSiteId},
        ${input.workTypeId},
        ${input.workDescription},
        ${input.stampType},
        ${input.lat},
        ${input.lon},
        ${input.accuracyM},
        ${input.positionTimestampMs},
        ${input.isCachedPosition},
        ${input.decisionMethod},
        ${input.nearestDistanceM},
        ${input.withinRadius},
        ${input.autoGenerated}
      )
      RETURNING id, stamped_at, work_date
    `;

    return NextResponse.json(
      { ok: true, stamp: rows[0], requestId },
      { status: 201 }
    );
  } catch (err) {
    console.error({ level: "error", event: "Failed to record stamp", requestId, err });
    return NextResponse.json(
      { ok: false, error: "Failed to record stamp", requestId },
      { status: 500 }
    );
  }
}
